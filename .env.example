# Database
POSTGRES_PASSWORD=changeme-in-production
DATABASE_URL=postgresql://parksaas:changeme-in-production@db:5432/parksaas

# JWT Secrets (min. 32 Zeichen - openssl rand -base64 48)
JWT_SECRET=generate-with-openssl-rand-base64-48
JWT_OPERATOR_SECRET=generate-with-openssl-rand-base64-48
JWT_ADMIN_SECRET=generate-with-openssl-rand-base64-48

# Mollie Connect (Platform-App)
# Erstellen unter: https://www.mollie.com/dashboard/developers/applications
MOLLIE_CLIENT_ID=app_xxxxxxxxxxxxxx
MOLLIE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOLLIE_REDIRECT_URI=https://yourdomain.com/api/mollie/connect/callback

# URLs
API_BASE=https://api.yourdomain.com
FRONTEND_BASE=https://yourdomain.com
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Platform
PLATFORM_NAME=ParkSaaS
PLATFORM_DEFAULT_COMMISSION=5.0

# E-Mail (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=ParkSaaS <noreply@example.com>

# Platform Admin
ADMIN_EMAIL=admin@parksaas.com
ADMIN_PASSWORD_HASH=generate-with-bcrypt

# Logging
LOG_LEVEL=info
NODE_ENV=production
