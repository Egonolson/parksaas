# =============================================================================
# ParkSaaS Backend Environment Configuration
# Copy this file to .env and fill in all values before starting
# =============================================================================

# --- Server ---
NODE_ENV=development
PORT=3000
API_VERSION=v1

# --- Database ---
# PostgreSQL connection string
DATABASE_URL=postgresql://parksaas:password@localhost:5432/parksaas_dev
# Pool settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# --- JWT Authentication ---
# MUST be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_random_string_of_at_least_32_characters
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Platform Admin JWT (separate secret for platform admin routes)
PLATFORM_ADMIN_SECRET=change_me_to_another_random_string_of_at_least_32_chars

# --- Platform Admin ---
PLATFORM_ADMIN_EMAIL=admin@parksaas.io
PLATFORM_ADMIN_PASSWORD_HASH=  # bcrypt hash of admin password

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20

# --- Mollie ---
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOLLIE_PARTNER_CLIENT_ID=app_xxxxxxxxxxxxxxxxxxxxxx
MOLLIE_PARTNER_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOLLIE_REDIRECT_URI=https://app.parksaas.io/oauth/callback
MOLLIE_WEBHOOK_BASE_URL=https://api.parksaas.io

# --- Platform Commission Default ---
DEFAULT_COMMISSION_PERCENT=5.00

# --- Logging ---
LOG_LEVEL=debug
LOG_FORMAT=combined

# --- Signing Token ---
SIGNING_TOKEN_EXPIRES_DAYS=7
